#!/bin/sh
set -e

case "$1" in
    configure)
        if ! getent group stamp >/dev/null 2>&1; then
            addgroup --system stamp
        fi
        if ! getent passwd stamp >/dev/null 2>&1; then
            adduser --system --ingroup stamp --no-create-home \
                --home /nonexistent --shell /usr/sbin/nologin stamp
        fi
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload
            deb-systemd-invoke enable stamp-suite.service
        fi
        ;;
esac

#DEBHELPER#

exit 0
